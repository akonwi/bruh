{
  "name": "bruh",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["edge", "runtime", "web"],
  "scripts": {
    "dev:web": "cd web && bun run dev",
    "dev:runtime": "cd runtime && bun run dev",
    "dev:edge": "cd edge && bun run dev",
    "build": "bun run build:web && bun run build:runtime && bun run build:edge",
    "build:web": "cd web && bun run build",
    "build:runtime": "cd runtime && bun run build",
    "build:edge": "cd edge && bun run build",
    "typecheck": "bun run typecheck:web && bun run typecheck:runtime && bun run typecheck:edge",
    "typecheck:web": "cd web && bun run typecheck",
    "typecheck:runtime": "cd runtime && bun run typecheck",
    "typecheck:edge": "cd edge && bun run typecheck"
  }
}
