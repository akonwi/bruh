# API keys for model providers (at least one required)
# Copy this file to .dev.vars and fill in your values.
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key

# Host for MCP OAuth callbacks (required for OAuth MCP servers)
HOST=http://localhost:8790

# Frontend origin for post-OAuth redirect (dev only — not needed in production)
APP_ORIGIN=http://localhost:5173

# MCP server tokens (servers auto-connect when token is present)
# GITHUB_MCP_TOKEN=ghp_your-github-token
